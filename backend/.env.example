# Copy this file to .env and fill in your values

PORT=3001

# ── Gmail SMTP (recommended) ──────────────────────────────────
# 1. Go to myaccount.google.com → Security → 2-Step Verification → App Passwords
# 2. Create an App Password for "Mail"
# 3. Use that 16-char password below (NOT your Gmail password)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=yourname@gmail.com
SMTP_PASS=xxxx xxxx xxxx xxxx

# ── Outlook / Office 365 ──────────────────────────────────────
# SMTP_HOST=smtp.office365.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=yourname@outlook.com
# SMTP_PASS=yourpassword

# ── Yahoo Mail ────────────────────────────────────────────────
# SMTP_HOST=smtp.mail.yahoo.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=yourname@yahoo.com
# SMTP_PASS=your_app_password

EMAIL_FROM_NAME=Livio Building Systems
EMAIL_FROM_ADDRESS=yourname@gmail.com

FRONTEND_ORIGIN=http://127.0.0.1:4173,http://localhost:4173,http://localhost:5500

# ── Local dev fallback (used when DATABASE_URL is not set) ──────────────────
DB_FILE=./data/db.json
UPLOAD_DIR=./uploads

# Optional: persistent filesystem root for a mounted disk.  On Railway this
# is set automatically to $RAILWAY_VOLUME_MOUNT_PATH; leave blank locally.
PERSISTENT_ROOT=

# ── Railway Postgres (production app-state storage) ────────────────────────
# When DATABASE_URL is set, the backend reads/writes the app state (projects,
# activeId, etc.) from a Postgres `app_state` table instead of db.json.  On
# Railway this is set automatically when you link the Postgres service to
# the Project-Managment service as a variable reference:
#
#   DATABASE_URL = ${{ Postgres.DATABASE_URL }}
#
# Uploaded files are ALWAYS served from the mounted volume at UPLOAD_DIR —
# Postgres only holds the JSON app state, not the file bytes.
DATABASE_URL=

# Optional.  Railway's internal Postgres hostname (ends in .railway.internal)
# doesn't require SSL; the public proxy does.  The driver auto-detects this,
# but you can force-disable SSL here if needed.
# DATABASE_SSL=false

# Optional pool size override.  Railway's free-tier Postgres has limited
# connection slots, so keep this modest.
# DATABASE_POOL_MAX=5

# Optional upload tuning
# MAX_UPLOAD_MB=500

# Copy this file to .env and fill in your values

PORT=3001

# ── Gmail SMTP (recommended) ──────────────────────────────────
# 1. Go to myaccount.google.com → Security → 2-Step Verification → App Passwords
# 2. Create an App Password for "Mail"
# 3. Use that 16-char password below (NOT your Gmail password)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=yourname@gmail.com
SMTP_PASS=xxxx xxxx xxxx xxxx

# ── Outlook / Office 365 ──────────────────────────────────────
# SMTP_HOST=smtp.office365.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=yourname@outlook.com
# SMTP_PASS=yourpassword

# ── Yahoo Mail ────────────────────────────────────────────────
# SMTP_HOST=smtp.mail.yahoo.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=yourname@yahoo.com
# SMTP_PASS=your_app_password

EMAIL_FROM_NAME=Livio Building Systems
EMAIL_FROM_ADDRESS=yourname@gmail.com

FRONTEND_ORIGIN=http://127.0.0.1:4173,http://localhost:4173,http://localhost:5500
# Local defaults. On Railway, a mounted volume via PERSISTENT_ROOT or
# RAILWAY_VOLUME_MOUNT_PATH will override these starter relative paths.
DB_FILE=./data/db.json
UPLOAD_DIR=./uploads

# Optional: persistent filesystem root for Railway Volume or any mounted disk.
# If set, the backend will default to:
#   DB_FILE=<PERSISTENT_ROOT>/data/db.json
#   UPLOAD_DIR=<PERSISTENT_ROOT>/uploads
# Railway also exposes RAILWAY_VOLUME_MOUNT_PATH when a volume is attached.
PERSISTENT_ROOT=

# Optional: Supabase-backed shared project data + file storage
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_DB_TABLE=app_state
SUPABASE_DB_ROW_ID=main
SUPABASE_STORAGE_BUCKET=uploads

# Optional: file storage driver override
# Valid values: local, supabase, r2
FILE_STORAGE_DRIVER=

# Optional: Cloudflare R2-backed file storage
# If these are set, file uploads can go to R2 while project data stays local or Supabase.
CF_R2_ACCOUNT_ID=
CF_R2_ACCESS_KEY_ID=
CF_R2_SECRET_ACCESS_KEY=
CF_R2_BUCKET=
